# API Configuration
# Set to 'mock' to use mock API server, 'production' to use real backend
VITE_API_MODE=mock

# Production API URL (FastAPI backend)
VITE_API_URL=http://localhost:8000

# Mock API URL (Flask mock server for development)
VITE_MOCK_API_URL=http://localhost:5000

# Application Title
VITE_APP_TITLE=PS Engagement Tracker
