    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.20.0",
    "remark-gfm": "^4.0.0",
    "recharts": "^2.15.4",
    "tailwindcss": "^3.3.0",
    "zustand": "^4.4.0"
